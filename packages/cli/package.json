{
  "name": "@dtax/cli",
  "version": "0.1.0",
  "description": "dTax CLI — Calculate crypto taxes from the command line. 23 exchange CSV parsers, FIFO/LIFO/HIFO/Specific ID, Form 8949 export, wash sale detection",
  "license": "AGPL-3.0",
  "homepage": "https://getdtax.com",
  "bugs": "https://github.com/dTaxLab/dtax/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dTaxLab/dtax.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "crypto",
    "tax",
    "cli",
    "bitcoin",
    "cryptocurrency",
    "calculator",
    "form-8949",
    "schedule-d",
    "csv",
    "terminal",
    "fifo",
    "cost-basis",
    "capital-gains",
    "wash-sale",
    "defi",
    "tax-reporting",
    "open-source",
    "typescript"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dtax": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup src/index.ts --format cjs --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dtax/tax-engine": "workspace:*",
    "@dtax/shared-types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
