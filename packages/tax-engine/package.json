{
  "name": "@dtax/tax-engine",
  "version": "0.1.0",
  "description": "Open source crypto tax calculation engine - FIFO, LIFO, HIFO, Specific ID",
  "license": "AGPL-3.0",
  "homepage": "https://getdtax.com",
  "bugs": "https://github.com/dTaxLab/dtax/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dTaxLab/dtax.git",
    "directory": "packages/tax-engine"
  },
  "keywords": [
    "crypto",
    "tax",
    "bitcoin",
    "fifo",
    "lifo",
    "hifo",
    "cost-basis",
    "form-8949",
    "schedule-d",
    "wash-sale",
    "csv-parser",
    "ethereum",
    "capital-gains"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dtax/shared-types": "workspace:*",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
