{
  "name": "@dtax/shared-types",
  "version": "0.1.0",
  "description": "Shared TypeScript type definitions for DTax",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/dTaxLab/dtax/tree/main/packages/shared-types",
  "repository": {
    "type": "git",
    "url": "https://github.com/dTaxLab/dtax.git",
    "directory": "packages/shared-types"
  },
  "keywords": [
    "crypto",
    "tax",
    "typescript",
    "types"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
