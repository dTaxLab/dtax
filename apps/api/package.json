{
    "name": "@dtax/api",
    "version": "0.1.0",
    "private": true,
    "description": "DTax backend API server",
    "license": "SEE LICENSE IN ../../LICENSE-COMMERCIAL",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsup src/index.ts --format cjs --dts",
        "start": "node dist/index.js",
        "test": "vitest run",
        "lint": "eslint src/",
        "clean": "rm -rf dist",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "db:seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@dtax/shared-types": "workspace:*",
        "@dtax/tax-engine": "workspace:*",
        "@fastify/cors": "^10.0.0",
        "@fastify/multipart": "^9.4.0",
        "@prisma/client": "^6.0.0",
        "ccxt": "^4.5.42",
        "dotenv": "^16.4.0",
        "fastify": "^5.0.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "pino-pretty": "^13.1.3",
        "prisma": "^6.0.0",
        "tsup": "^8.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.4.0",
        "vitest": "^2.1.9"
    }
}