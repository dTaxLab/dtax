{
  "name": "@dtax/api",
  "version": "0.1.0",
  "private": true,
  "description": "DTax backend API server",
  "license": "SEE LICENSE IN ../../LICENSE-COMMERCIAL",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --dts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "openapi:export": "tsx scripts/export-openapi.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dtax/shared-types": "workspace:*",
    "@dtax/tax-engine": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^10.43.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "ccxt": "^4.5.42",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "fastify-zod-openapi": "^4.1.2",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "zod": "^3.23.0",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/qrcode": "^1.5.6",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
